{
  "name": "sypher",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "check:mdx": "node scripts/validate-mdx.mjs",
    "predev": "kill-port 3000",
    "dev": "docusaurus start",
    "docusaurus": "docusaurus",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "prestart": "kill-port 3000",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=16384 docusaurus start",
    "start:vercel": "node scripts/start-for-vercel.mjs",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=16384 docusaurus build",
    "blog:bake": "node scripts/bake-blog-posts.mjs",
    "blog:preview": "npm run blog:bake && cross-env NODE_OPTIONS=--max-old-space-size=16384 docusaurus build && docusaurus serve",
    "deploy:vercel": "node scripts/deploy-vercel.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/plugin-client-redirects": "^3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "@mdxeditor/editor": "^4.0.4",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.109.0",
    "@sypher/auth-core": "*",
    "@sypher/career-tools": "*",
    "@sypher/course-catalog": "*",
    "clsx": "^2.0.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "papaparse": "^5.5.4",
    "prism-react-renderer": "^2.3.0",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@mdx-js/mdx": "^3.1.1",
    "@types/papaparse": "^5.5.2",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "glob": "^13.0.6",
    "kill-port": "^2.0.1",
    "puppeteer": "^24.43.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
