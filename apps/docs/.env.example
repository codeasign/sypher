# Claude Code + OpenRouter
ANTHROPIC_AUTH_TOKEN=sk-or-v1-replace-me
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_MODEL=anthropic/claude-sonnet-4.5

# Diagram generation — only one provider needed
RUNPOD_API_KEY=replace-me
RUNPOD_ENDPOINT_ID=replace-me
OPENAI_API_KEY=sk-replace-me

# Duration display toggles
# Set to "true" to show course duration on home / courses listing pages
SHOW_DURATION_ON_LANDING=false
# Set to "true" to show course duration on course detail pages
SHOW_DURATION_ON_CONTENT=false


# Web3Forms access key for the Corporate Training, Resume Review, and Mock Interview contact forms (https://web3forms.com)
WEB3FORMS_ACCESS_KEY=replace-me

# Bunny.net Storage — CDN for blog posts (cover images + inline images) and
# profile resume uploads. BUNNY_STORAGE_ACCESS_KEY must be the Storage Zone's
# own Password (Storage Zone → FTP & API Access), not your account API key —
# using the account key here causes a 401. BUNNY_STORAGE_HOSTNAME must match
# that same FTP & API Access tab exactly (some regions use e.g.
# ny.storage.bunnycdn.com, not the plain default). BUNNY_PULL_ZONE_URL is the
# Pull Zone's hostname (Pull Zones → your zone → origin = the Storage Zone
# above), needed since Storage Zones aren't publicly readable on their own.
BUNNY_STORAGE_ZONE=replace-me
BUNNY_STORAGE_ACCESS_KEY=replace-me
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_PULL_ZONE_URL=https://replace-me.b-cdn.net

# Vercel Deploy Hook — Project → Settings → Git → Deploy Hooks in the Vercel
# dashboard. Used by `npm run deploy:vercel` to trigger a production rebuild
# (which re-bakes blog posts from Supabase) without a git push.
VERCEL_DEPLOY_HOOK_URL=replace-me

# Razorpay — payment gateway for Free → Paid upgrades. key_id is safe for the
# client; key_secret and webhook secret are SERVER-ONLY, read only inside
# api/razorpay/*.js (Vercel Serverless Functions) — never expose in
# docusaurus.config.js customFields.
RAZORPAY_KEY_ID=rzp_test_replace-me
RAZORPAY_KEY_SECRET=replace-me
RAZORPAY_WEBHOOK_SECRET=replace-me

# Fixed annual price, GST-inclusive, INTEGER paise (smallest INR unit
# Razorpay expects — e.g. ₹3,999 => 399900). Decide the actual number
# separately; this is a placeholder until then.
PAID_UPGRADE_PRICE_INR_PAISE=REPLACE-ME
PAID_UPGRADE_GST_RATE=0.18
PAID_UPGRADE_DURATION_DAYS=365

# SERVER-ONLY — Supabase service role key. Used exclusively by api/razorpay/
# and api/cron/ (via api/_lib/supabaseAdmin.js) to bypass RLS when verifying
# a payment and upgrading a profile. Never add to customFields in
# docusaurus.config.js, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Shared secret Vercel Cron sends as a Bearer token — set this in Vercel's
# env vars; Vercel automatically attaches it as Authorization on
# cron-triggered requests.
CRON_SECRET=replace-me

# Base URL for the client to call /api/* from. Empty = same-origin relative
# fetch — correct everywhere (production and `vercel dev` locally both
# serve the site and /api/* from the same origin). Kept as a future escape
# hatch only; leave empty.
API_BASE_URL=
