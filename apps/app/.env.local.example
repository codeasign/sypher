NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_PAID_UPGRADE_PRICE_INR_PAISE=
# Web3Forms access key — same value as apps/docs' WEB3FORMS_ACCESS_KEY.
# Web3Forms keys are designed to be used client-side, so NEXT_PUBLIC_ is safe here.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# SERVER-ONLY — read exclusively by app/api/razorpay/* and app/api/cron/*
# Route Handlers (and src/lib/supabaseAdmin.ts, gst.ts, finalizePayment.ts).
# Never prefix these with NEXT_PUBLIC_ — doing so would bundle them into
# client JS.
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAID_UPGRADE_GST_RATE=
PAID_UPGRADE_DURATION_DAYS=
CRON_SECRET=
# Bearer secret checked by app/api/revalidate — set as a custom header on
# the Supabase Database Webhook (blog_posts insert/update).
BLOG_REVALIDATE_SECRET=
# Optional escape hatch for api/* CORS headers — leave unset for same-origin (default).
CORS_ALLOWED_ORIGIN=

NEXT_PUBLIC_BUNNY_STORAGE_ZONE=
NEXT_PUBLIC_BUNNY_STORAGE_ACCESS_KEY=
NEXT_PUBLIC_BUNNY_STORAGE_HOSTNAME=
NEXT_PUBLIC_BUNNY_PULL_ZONE_URL=
